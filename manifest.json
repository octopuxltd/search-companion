{
  "manifest_version": 2,
  "name": "Search sidebar",
  "version": "1.0.9",
  "description": "Companion sidebar that opens on Google search result pages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "search-companion@paulannett.co.uk",
      "update_url": "https://octopuxltd.github.io/search-companion/update.json",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "images/search-icon-v3.svg",
    "96": "images/search-icon-v3.svg"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "*://www.google.com/*",
    "*://www.google.co.uk/*",
    "https://*.workers.dev/*"
  ],
  "browser_action": {
    "default_title": "Search sidebar",
    "default_icon": {
      "48": "images/search-icon-v3.svg",
      "96": "images/search-icon-v3.svg"
    }
  },
  "sidebar_action": {
    "default_title": "Search sidebar",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "images/search-icon-v3.svg",
    "open_at_install": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://octopuxltd.github.io/search-companion/*"],
      "js": ["install-overlay.js"],
      "run_at": "document_end"
    }
  ]
}
