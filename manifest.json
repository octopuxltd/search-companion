{
  "manifest_version": 2,
  "name": "Search sidebar",
  "version": "1.0.99",
  "description": "Companion sidebar that opens on Google search result pages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "search-companion@paulannett.co.uk",
      "update_url": "https://octopuxltd.github.io/search-companion/update.json",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "images/search-icon-auto-v2.svg",
    "96": "images/search-icon-auto-v2.svg"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "webNavigation",
    "webRequest",
    "<all_urls>",
    "*://www.google.com/*",
    "*://www.google.co.uk/*",
    "https://*.workers.dev/*"
  ],
  "browser_action": {
    "default_title": "Search sidebar",
    "default_icon": {
      "16": "images/search-icon-silhouette-v1.svg",
      "32": "images/search-icon-silhouette-v1.svg"
    }
  },
  "sidebar_action": {
    "default_title": "Search sidebar",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "images/search-icon-silhouette-v1.svg",
    "open_at_install": true
  },
  "background": {
    "scripts": ["blocked-pages.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://octopuxltd.github.io/search-companion/*"],
      "js": ["install-overlay.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://octopuxltd.github.io/search-companion/*"],
      "js": ["page-context.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://www.google.com/search*", "*://www.google.co.uk/search*"],
      "js": ["serp-overlay.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": ["images/no-connection.svg"]
}
